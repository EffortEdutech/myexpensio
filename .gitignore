# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js / build outputs ───────────────────────────────────────────────────
.next/
out/
build/
/coverage
.turbo/

# ── Package manager ───────────────────────────────────────────────────────────
package-lock.json
yarn.lock
.pnpm-debug.log*

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# .env.production is SAFE to commit if it contains only public NEXT_PUBLIC_* vars
# .env.local.example is SAFE to commit if it contains placeholders only

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase/.temp/
supabase/snippets/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Audit / generated artifacts ───────────────────────────────────────────────
audit-output/
*.orig

# ── Debug / logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.tmp
