# apps/user/.env.local additions — Billing / Stripe
# Copy the relevant keys into your .env.local

NEXT_PUBLIC_APP_URL=http://localhost:3100
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for checkout, webhooks, and billing portal.

STRIPE_SECRET_KEY=sk_test_xxx

# Price IDs for individual user subscriptions (User App checkout)
# Create these in your Stripe dashboard → Products → Pricing
STRIPE_PRICE_PRO=price_xxx          # RM18 / month
STRIPE_PRICE_PREMIUM=price_xxx      # RM29 / month

# Webhook signing secret (Stripe Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: Stripe billing portal (pre-built customer portal)
# Stripe Dashboard → Billing → Customer portal → Configure
STRIPE_PORTAL_RETURN_URL=https://myexpensio-jade.vercel.app/settings/billing

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_USER_APP_URL=https://myexpensio-jade.vercel.app
