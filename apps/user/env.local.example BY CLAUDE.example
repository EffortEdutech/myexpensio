# apps/user/.env.local
# Copy this file → .env.local and fill in your LOCAL Supabase values.
# Run `supabase start` then `supabase status` to get these values.
# 🚫 NEVER commit .env.local — it is git-ignored.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Publishable/anon key (safe for browser) — from: supabase status
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste anon key here>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<paste anon key here>

# Secret key — server-side only, NO NEXT_PUBLIC_ prefix — from: supabase status
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key here>
