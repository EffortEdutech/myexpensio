# ── Dependencies ──────────────────────────────────────────────────────────────
# No leading slash — matches node_modules at ANY depth (root + all workspaces)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
build/
/coverage

# ── Package manager ───────────────────────────────────────────────────────────
# Commit pnpm-lock.yaml (yes), ignore npm/yarn lockfiles
package-lock.json
yarn.lock
.pnpm-debug.log*

# ── Environment variables ─────────────────────────────────────────────────────
# Never commit real secrets
.env
.env.local
.env.*.local
# .env.production is SAFE to commit (public NEXT_PUBLIC_ vars only, no secrets)
# .env.local.example is SAFE to commit (placeholder template)

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase/.temp/
# Ignore auto-saved SQL snippets from Supabase Studio
supabase/snippets/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Debug / logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.tmp

RUNBOOK_LOCAL_DEV.md