# Do NOT add node-linker=hoisted here.
# This monorepo has incompatible React versions across apps (user=18, user-mobile-v2=19)
# which causes hoisting conflicts on Vercel.
#
# public-hoist-pattern is safe: it hoists only matching packages to root node_modules/
# without changing the linker. Required so @babel/core (deep in the pnpm virtual store)
# can resolve babel-preset-expo during EAS Android builds.
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=*metro*